{
  "name": "V2 Article Creation Pipeline",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "article-job",
        "responseMode": "onReceived",
        "responseData": "firstEntryJson"
      },
      "id": "article-webhook",
      "name": "Article Job Submitted",
      "type": "n8n-nodes-base.webhook",
      "position": [240, 300]
    },
    {
      "parameters": {
        "jsCode": "const job = $input.first().json;\nreturn [{ json: { \n  jobId: job.jobId, \n  styleCode: job.styleCode || 'unknown',\n  articleCount: job.articleCount || 0,\n  submittedAt: job.submittedAt || new Date().toISOString(),\n  attempts: 0,\n  maxAttempts: 24\n}}];"
      },
      "id": "init-job",
      "name": "Init Job State",
      "type": "n8n-nodes-base.code",
      "position": [480, 300]
    },
    {
      "parameters": {
        "amount": 30,
        "unit": "seconds"
      },
      "id": "wait-30s",
      "name": "Wait 30s",
      "type": "n8n-nodes-base.wait",
      "position": [720, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://v2-article-backend.azurewebsites.net/api/jobs/{{ $json.jobId }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "x-api-key", "value": "={{ $env.ARTICLE_BACKEND_KEY }}" }
          ]
        }
      },
      "id": "poll-job",
      "name": "Poll Job Status",
      "type": "n8n-nodes-base.httpRequest",
      "position": [960, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
          "conditions": [
            {
              "leftValue": "={{ $json.status }}",
              "rightValue": "complete",
              "operator": { "type": "string", "operation": "equals" }
            }
          ]
        }
      },
      "id": "is-done",
      "name": "Is Done?",
      "type": "n8n-nodes-base.if",
      "position": [1200, 300]
    },
    {
      "parameters": {
        "jsCode": "const job = $input.first().json;\nconst attempts = (job.attempts || 0) + 1;\nif (attempts >= job.maxAttempts) {\n  return [{ json: { ...job, timedOut: true } }];\n}\nreturn [{ json: { ...job, attempts } }];"
      },
      "id": "increment",
      "name": "Increment Attempts",
      "type": "n8n-nodes-base.code",
      "position": [1200, 500]
    },
    {
      "parameters": {
        "jsCode": "const job = $input.first().json;\nconst start = new Date(job.submittedAt);\nconst duration = Math.round((Date.now() - start.getTime()) / 60000);\n\nlet msg;\nif (job.timedOut) {\n  msg = `*Article Job Timed Out ⏰*\\n\\nStyle: ${job.styleCode}\\nJob ID: ${job.jobId}\\nWaited: ${duration} min\\nCheck manually: https://articles.v2retail.net/jobs/${job.jobId}`;\n} else if (job.status === 'complete') {\n  msg = `*Article Creation Complete ✅*\\n\\nStyle: ${job.styleCode}\\nArticles: ${job.articleCount} generated\\nDuration: ${duration} min\\nReview at: https://articles.v2retail.net/jobs/${job.jobId}`;\n} else {\n  msg = `*Article Job Failed ❌*\\n\\nStyle: ${job.styleCode}\\nError: ${job.error || 'Unknown error'}\\nJob ID: ${job.jobId}`;\n}\n\nreturn [{ json: { message: msg } }];"
      },
      "id": "format-result",
      "name": "Format Completion",
      "type": "n8n-nodes-base.code",
      "position": [1440, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://openclaw-agent.happyocean-047968bd.centralindia.azurecontainerapps.io/webhook/send",
        "sendBody": true,
        "contentType": "json",
        "body": "={ \"to\": \"whatsapp\", \"message\": \"{{ $json.message }}\" }"
      },
      "id": "send-result",
      "name": "Send Result",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1680, 300]
    }
  ],
  "connections": {
    "Article Job Submitted": { "main": [[{ "node": "Init Job State" }]] },
    "Init Job State": { "main": [[{ "node": "Wait 30s" }]] },
    "Wait 30s": { "main": [[{ "node": "Poll Job Status" }]] },
    "Poll Job Status": { "main": [[{ "node": "Is Done?" }]] },
    "Is Done?": {
      "main": [
        [{ "node": "Format Completion" }],
        [{ "node": "Increment Attempts" }]
      ]
    },
    "Increment Attempts": { "main": [[{ "node": "Wait 30s" }]] },
    "Format Completion": { "main": [[{ "node": "Send Result" }]] }
  },
  "active": true,
  "settings": { "timezone": "Asia/Kolkata" }
}
